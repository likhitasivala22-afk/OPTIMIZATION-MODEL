

import matplotlib.pyplot as plt


best_profit = 0
best_x = 0
best_y = 0


for x in range(0, 100):
    for y in range(0, 100):

        if (2*x + 4*y <= 100) and (x + 3*y <= 90):

            profit = 20*x + 30*y

            if profit > best_profit:
                best_profit = profit
                best_x = x
                best_y = y

print("✅ Optimal Solution Found")
print("Product A =", best_x)
print("Product B =", best_y)
print("Maximum Profit =", best_profit)


x_vals = list(range(0, 60))
y1 = [(100 - 2*i)/4 for i in x_vals]   # constraint 1
y2 = [(90 - i)/3 for i in x_vals]      # constraint 2

plt.plot(x_vals, y1, label="2x + 4y ≤ 100")
plt.plot(x_vals, y2, label="x + 3y ≤ 90")

plt.scatter(best_x, best_y)
plt.text(best_x, best_y, f'Optimal ({best_x},{best_y})')

plt.xlabel("Product A")
plt.ylabel("Product B")
plt.title("Optimization Graph")
plt.legend()
plt.grid()
plt.show()

print("🎉 Project Completed Successfully!")
